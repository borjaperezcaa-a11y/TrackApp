# ─── Supabase (proyecto en región UE) ───────────────────────────────────────
# Copia este fichero a .env.local y rellena con los valores de tu proyecto.
# En el CLIENTE solo viaja la anon key. NUNCA pongas la service_role aquí
# (no la necesitamos: la emisión va por función Postgres SECURITY DEFINER).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# URL pública de la app (para callbacks OAuth y enlaces de email)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── IA para leer tickets de gasto (SOLO SERVIDOR) ──────────────────────────
# Clave de la API de Claude (console.claude.com). NUNCA con prefijo NEXT_PUBLIC:
# es un secreto y solo se usa en rutas de servidor. Sin ella, el escaneo con IA
# se desactiva (puedes seguir registrando gastos a mano).
ANTHROPIC_API_KEY=

# ─── Rutas y km (OpenRouteService, SOLO SERVIDOR) ───────────────────────────
# Clave gratuita de openrouteservice.org para el buscador de lugares y el
# cálculo de km (perfil camión). Sin ella, origen/destino son texto libre y el
# km se introduce a mano. NUNCA con prefijo NEXT_PUBLIC (es un secreto).
OPENROUTESERVICE_API_KEY=

# ─── Código postal → localidad (GeoNames, SOLO SERVIDOR) ────────────────────
# Usuario gratuito de geonames.org con los "Free Web Services" activados.
# Al escribir un CP en un viaje, rellena la localidad (cobertura europea).
# Sin él, el CP se escribe a mano. NUNCA con prefijo NEXT_PUBLIC.
GEONAMES_USERNAME=

# ─── Registro por invitación (SOLO SERVIDOR) ────────────────────────────────
# Emails autorizados a crear cuenta, separados por comas. Si se deja vacío, el
# registro queda abierto a cualquiera. Para una prueba privada, pon aquí solo
# los emails permitidos: aunque la URL sea pública, nadie más podrá registrarse.
# Ej.: ALLOWED_EMAILS="cunao@example.com,tu@example.com"
ALLOWED_EMAILS=
